<% layout("/layouts/boilerplate") %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-11 col-sm-8 col-md-6 col-lg-4">

      <div class="card shadow-sm border-0 rounded-4 p-4">
        <h2 class="text-center fw-bold mb-4">Sign Up at StayEase ✍️</h2>

        <form action="/signup" method="POST" class="needs-validation" novalidate>
          <div class="mb-3">
            <label for="username" class="form-label">Username</label>
            <input type="text" name="username" id="username" class="form-control" required />
            <div class="valid-feedback">Looks good!</div>
            <div class="invalid-feedback">Please enter the username</div>
          </div>

          <div class="mb-3">
            <label for="email" class="form-label">Email</label>
            <input type="email" name="email" id="email" class="form-control" required />
            <div class="invalid-feedback">Please enter a valid email</div>
          </div>

          <div class="mb-3">
            <label for="password" class="form-label">Password</label>
            <input type="password" name="password" id="password" class="form-control" required />
            <div class="invalid-feedback">Please enter Password!</div>
          </div>

          <button class="btn btn-danger w-100 mt-2">Sign Up</button>
        </form>

        <p class="text-center text-muted mt-3 mb-0" style="font-size: 0.9rem;">
          Already have an account? <a href="/login" class="text-danger fw-bold">Login</a>
        </p>
      </div>

    </div>
  </div>
</div>